<local:IntegraWindow x:Class="IntegraXL.Windows.ToneBankWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegraXL.Windows"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid MaxHeight="600">

        <DataGrid ItemsSource="{Binding ToneBank}"
                  SelectedItem="{Binding DeviceContext.SelectedTone}"
                  AutoGenerateColumns="False"
                  VerticalAlignment="Stretch"
                  IsReadOnly="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.IsVirtualizing="True">

            <DataGrid.Columns>

                <DataGridTextColumn Binding="{Binding Path=ID, StringFormat='0000'}"
                                               Header="ID"
                                               MinWidth="36"/>


                <DataGridTextColumn Binding="{Binding Path=Name}"
                                               Header="Tone Name"
                                               MinWidth="200"/>

                <DataGridTextColumn Binding="{Binding Path=Category}"
                                               Header="Category"
                                               MinWidth="100"/>

            </DataGrid.Columns>
        </DataGrid>
      
    </Grid>
</local:IntegraWindow>
