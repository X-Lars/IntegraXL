<UserControl x:Class="IntegraXL.UserControls.MFX.StepFilter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegraXL.UserControls.MFX"
             xmlns:ic="clr-namespace:IntegraControls;assembly=IntegraControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid DataContext="{Binding MFX}">
        <ic:StepControl
            Min="0" Max="127"
            Step01="{Binding [0]}"
            Step02="{Binding [1]}"
            Step03="{Binding [2]}"
            Step04="{Binding [3]}"
            Step05="{Binding [4]}"
            Step06="{Binding [5]}"
            Step07="{Binding [6]}"
            Step08="{Binding [7]}"
            Step09="{Binding [8]}"
            Step10="{Binding [9]}"
            Step11="{Binding [10]}"
            Step12="{Binding [11]}"
            Step13="{Binding [12]}"
            Step14="{Binding [13]}"
            Step15="{Binding [14]}"
            Step16="{Binding [15]}"
            />
    </Grid>
</UserControl>
