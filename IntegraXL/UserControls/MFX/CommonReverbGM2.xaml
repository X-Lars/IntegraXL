<UserControl x:Class="IntegraXL.UserControls.MFX.CommonReverbGM2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:xl="clr-namespace:ControlsXL;assembly=ControlsXL"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <GroupBox Header="Reverb">

        <StackPanel>

            <xl:NumericTextBox MinValue="0" MaxValue="5"
                               Value="{Binding CommonReverb[0]}"/>

            <xl:NumericTextBox MinValue="0" MaxValue="127"
                               Value="{Binding CommonReverb[3]}"/>

        </StackPanel>
    </GroupBox>
</UserControl>
