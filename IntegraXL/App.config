<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
  <connectionStrings>
    <add name="Integra" connectionString="data source=.\SQLEXPRESS; initial catalog=Integra; integrated security=SSPI; AttachDbFilename=|DataDirectory|\Integra.mdf;" providerName="System.Data.SqlClient"/>
    <add name="IntegraLite" connectionString="data source=.\Integra.db;Version=3;" providerName="System.Data.SqlClient"/>
  </connectionStrings>
</configuration>